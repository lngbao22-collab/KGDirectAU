{
  "model": "SimKGC-AU",
  "model_encoder_path": "models/encoders/bert_encoder.py",
  "model_loss_path": "models/losses/au_loss.py",
  "model_sampler_path": "",
  "model_strategy_path": "models/strategies/kgau_strategy.py",

  "dataset": "WN18RR",
  "task": "both",
  "train_path": "data/WN18RR/preprocessed/train.txt.json",
  "valid_path": "data/WN18RR/preprocessed/valid.txt.json",
  "test_path": "data/WN18RR/preprocessed/test.txt.json",
  "valid_w_label_path": "data/WN18RR/preprocessed/valid_w_label.txt.json",
  "test_w_label_path": "data/WN18RR/preprocessed/test_w_label.txt.json",

  "output_dir_prefix": "logs/SimKGC-AU_WN18RR",

  "additive_margin": 0.02,
  "batch_size": 512,
  "bert_encoder": "distilbert-base-uncased",
  "dim": 768,
  "dropout": 0.1,
  "epochs": 50,
  "eval_every_n_step": 10000,
  "finetune_t": true,
  "gamma_q": 1.0,
  "gamma_t": 1.0,
  "gamma_h": 0.5,
  "gamma_ent": 0.0,
  "grad_clip": 10.0,
  "is_test": false,
  "lr": 5e-05,
  "lr_scheduler": "linear",
  "max_num_tokens": 50,
  "max_to_keep": 3,
  "neighbor_weight": 0.0,
  "pooling": "mean",
  "pre_batch": 0,
  "pre_batch_weight": 0.5,
  "print_freq": 20,
  "rerank_n_hop": 2,
  "seed": null,
  "tuni": 2.0,
  "use_amp": true,
  "use_link_graph": true,
  "use_self_negative": false,
  "weight_decay": 0.0001,
  "workers": 2,
  "warmup": 400
}
