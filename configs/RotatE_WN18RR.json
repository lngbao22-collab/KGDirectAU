{
  "model": "RotatE",
  "model_encoder_path": "models/encoders/rotate_encoder.py",
  "model_loss_path": "models/losses/adversarial_bce_loss.py",
  "model_sampler_path": "models/samplers/filtered_1_to_n_sampler.py",
  "model_strategy_path": "models/strategies/adversarial_strategy.py",

  "dataset": "WN18RR",
  "task": "both",
  "train_path": "data/WN18RR/preprocessed/train.txt",
