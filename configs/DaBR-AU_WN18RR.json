{
  "model": "DaBR-AU",
  "model_encoder_path": "models/encoders/dabr_encoder.py",
  "model_loss_path": "models/losses/au_loss.py",
  "model_sampler_path": "",
  "model_strategy_path": "models/strategies/kgau_strategy.py",

  "dataset": "WN18RR",
  "task": "both",
  "train_path": "data/WN18RR/preprocessed/train.txt.json",
  "valid_path": "data/WN18RR/preprocessed/valid.txt.json",
  "test_path": "data/WN18RR/preprocessed/test.txt.json",
  "valid_w_label_path": "data/WN18RR/preprocessed/valid_w_label.txt.json",
  "test_w_label_path": "data/WN18RR/preprocessed/test_w_label.txt.json",

  "output_dir_prefix": "logs/DaBR-AU_WN18RR",

  "dim": 500,
  "lr": 0.1,
  "batch_size": 100,
  "epochs": 40000,
  "n_sample": 5,
  "eval_every_n_step": 400,
  "epoch_per_test": 400,
  "lam": 0.5,
  "lmbda": 0.5,
  "lmbda_two": 0.01,
  "optim": "adagrad",
  "workers": 8,
  "early_stopping_patience": 10,
  "test_link": true,
  "test_triple": false,
  "gamma_q": 1.0,
  "gamma_t": 1.0,
  "gamma_h": 0.5,
  "gamma_ent": 0.0,
  "tuni": 2.0,
  "pre_batch": 20,
  "weight_decay": 0.1,
  "sample_freq": 1
}
