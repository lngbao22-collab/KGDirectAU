{
  "model": "SimKGC",
  "model_def": "models/strategies/simkgc.py",

  "dataset": "WN18RR",
  "task": "both",
  "bert_encoder": "distilbert-base-uncased",

  "train_path": "data/WN18RR/preprocessed/train.txt.json",
  "valid_path": "data/WN18RR/preprocessed/valid.txt.json",
  "test_path": "data/WN18RR/preprocessed/test.txt.json",
  "valid_label_path": "data/WN18RR/preprocessed/valid_w_label.txt.json",
  "test_label_path": "data/WN18RR/preprocessed/test_w_label.txt.json",

  "eval_model_path": "",
  "output_dir": "logs/SimKGC_WN18RR",

  "additive_margin": 0.02,
  "batch_size": 512,
  "dim": 768,
  "dropout": 0.1,
  "epochs": 50,
  "eval_every_n_step": 10000,
  "finetune_t": true,
  "grad_clip": 10.0,
  "is_test": false,
  "lr": 5e-05,
  "lr_scheduler": "linear",
  "max_num_tokens": 50,
  "max_to_keep": 3,
  "neighbor_weight": 0.0,
  "pooling": "mean",
  "pre_batch": 0,
  "pre_batch_weight": 0.5,
  "print_freq": 20,
  "rerank_n_hop": 2,
  "seed": null,
  "t": 0.05,
  "use_amp": true,
  "use_link_graph": true,
  "use_self_negative": false,
  "weight_decay": 0.0001,
  "workers": 2,
  "warmup": 400
}
